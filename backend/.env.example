# Node runtime
NODE_ENV=development
PORT=5001

# Required: MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/student_vault

# Required for WhatsApp webhook verification handshake
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace_with_verify_token

# Optional but recommended for securing POST /webhook requests
WHATSAPP_ACCESS_TOKEN=replace_with_access_token
